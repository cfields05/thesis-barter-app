// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int       @id @default(autoincrement()) 
  name  String?
  email String    @unique
  phone String?
  posts Post[]?
  role  Role?
}

enum Role {
  USER
  MODERATOR
  ADMIN
}


model DM {
  id   Int   @id @default(autoincrement())
  user User  @relation(fields: [userId], references: [id])


}

model Message {
  id   Int  @id @default(autoincrement())
  user User @relation(fields: [userId], references: [id])

}

model Log {
  id   Int  @id @default(autoincrement())
  user User    @relation(fields: [userId], references: [id])

}

model Post {
  id   Int  @id @default(autoincrement())
  user User    @relation(fields: [userId], references: [id])
  message String
  isComplete Boolean @default(false)
}

model Product {
  id          Int     @id @default(autoincrement())
  post        Post    @relation(fields: [postId], references: [id])
  user        User    @relation(fields: [userId], references: [id])
  cat         Cat     @relation(fields: [userId], references: [id])
  name        String
  description String
  condition   Cond
  location    String?
}

enum Cond {
  POOR
  FAIR
  NEW
}

model Service {
  id          Int    @id @default(autoincrement())
  post        Post   @relation(fields: [postId], references: [id])
  user        User   @relation(fields: [userId], references: [id])
  cat         Cat    @relation(fields: [userId], references: [id])
  name        String
  description String
}

model Cat {
  id   Int      @id @default(autoincrement())
  name String   @unique
  type CatType  
}

enum CatType {
  SERVICE
  PRODUCT
}

