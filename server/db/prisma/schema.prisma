// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int       @id @default(autoincrement())
  name     String?
  email    String    @unique
  phone    String?
  posts    Post[]
  role     Role?
  dms      DM[]
  messages Message[]
  logs     Log[]
  products Product[]
  services Service[]
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

model DM {
  id     Int  @id @default(autoincrement())
  user   User @relation(fields: [userId], references: [id])
  userId Int
}

model Message {
  id     Int  @id @default(autoincrement())
  user   User @relation(fields: [userId], references: [id])
  userId Int
}

model Log {
  id     Int  @id @default(autoincrement())
  user   User @relation(fields: [userId], references: [id])
  userId Int
}

model Post {
  id         Int       @id @default(autoincrement())
  user       User      @relation(fields: [userId], references: [id])
  userId     Int
  message    String
  isComplete Boolean   @default(false)
  products   Product[]
  services   Service[]
}

model Product {
  id          Int     @id @default(autoincrement())
  post        Post    @relation(fields: [postId], references: [id])
  postId      Int
  user        User    @relation(fields: [userId], references: [id])
  userId      Int
  cat         Cat     @relation(fields: [catId], references: [id])
  catId       Int
  name        String
  description String
  condition   Cond
  location    String?
}

enum Cond {
  POOR
  FAIR
  NEW
}

model Service {
  id          Int    @id @default(autoincrement())
  post        Post   @relation(fields: [postId], references: [id])
  postId      Int
  user        User   @relation(fields: [userId], references: [id])
  userId      Int
  cat         Cat    @relation(fields: [catId], references: [id])
  catId       Int
  name        String
  description String
}

model Cat {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  type     CatType
  products Product[]
  services Service[]
}

enum CatType {
  SERVICE
  PRODUCT
}
